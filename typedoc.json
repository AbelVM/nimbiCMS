{
  "entryPoints": [
    "src"
  ],
  "entryPointStrategy": "expand",
  "out": "docs",
  "exclude": [
    "**/tests/**"
  ],
  "json": "docs-typedoc.json",
  "disableSources": true,
  "highlightLanguages": [
    "javascript",
    "typescript",
    "html",
    "markdown",
    "bash",
    "json"
  ]
}