{
  "name": "nimbi-cms",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:example": "sh -c \"npm run build -- --outDir example/dist --config vite.config.js && vite example --port 5173 &\"",
    "build": "vite build",
    "build:lib": "vite build --config vite.config.js",
    "preview": "vite preview",
    "test": "npx vitest run",
    "gen-dts": "node scripts/gen-dts.js",
    "check-dts": "npx tsc --noEmit src/index.d.ts --lib es2015,dom --skipLibCheck"
  },
  "dependencies": {
    "bulma": "^1.0.4",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.4"
  },
  "devDependencies": {
    "comment-parser": "^0.7.6",
    "eslint": "^10.0.3",
    "glob": "^10.4.1",
    "jsdom": "^28.1.0",
    "reading-time": "^1.5.0",
    "terser": "^5.17.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "main": "dist/nimbi-cms.cjs.js",
  "module": "dist/nimbi-cms.es.js",
  "unpkg": "dist/nimbi-cms.js",
  "files": [
    "dist"
  ]
}
